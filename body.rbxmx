			<Item class="Script" referent="RBXF4A2D46DF9D94A8DA42CF610ED92E6D4">
				<Properties>
					<ProtectedString name="Source"><![CDATA[grp1 = script.Parent.G1:GetChildren()


while true do
wait(0)
if script.Parent.on.Value == true then
	
	for i = 1,#grp1 do
		grp1[i].Transparency = 0
		grp1[i].Material = Enum.Material.Neon
		grp1[i].Light.Enabled = true
	end
	


else
	for i = 1,#grp1 do
		grp1[i].Transparency = 0.35
		grp1[i].Material = Enum.Material.SmoothPlastic
		grp1[i].Light.Enabled = false
	end
	


end
end]]></ProtectedString>
