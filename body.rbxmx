			<Item class="Script" referent="RBX229E94A2A2414AA0919B40B947A71727">
				<Properties>
					<ProtectedString name="Source"><![CDATA[grp1 = script.Parent.G1:GetChildren()


while true do
wait(0)
if script.Parent.on.Value == true then
	wait(0.35)
	for i = 1,#grp1 do
	grp1[i].Light.Enabled = true
	grp1[i].Transparency = 0
	end
	

	
	wait(0.35)
	
	for i = 1,#grp1 do
	grp1[i].Light.Enabled = false
	grp1[i].Transparency = 1
	end
	

	
else
	for i = 1,#grp1 do
	grp1[i].Light.Enabled = false
	grp1[i].Transparency = 1
	end
	

	
end
end]]></ProtectedString>
