		<Item class="Script" referent="RBXBCBB69A38F164AB5A5AEBAC6ADDB7B9B">
			<Properties>
				<ProtectedString name="Source"><![CDATA[grp1 = script.Parent.G1:GetChildren()
grp2 = script.Parent.G2:GetChildren()

while true do
wait(0)
if script.Parent.on.Value == true then
	
	for i = 1,#grp1 do
		grp1[i].BrickColor = BrickColor.new("Maroon")
		grp1[i].Material = Enum.Material.Neon
		grp1[i].Light.Enabled = true
	end
	
	for i = 1,#grp2 do
		grp2[i].Material = Enum.Material.Neon
		grp2[i].Light.Enabled = true
	end
	


else
	for i = 1,#grp1 do
		grp1[i].BrickColor = BrickColor.new("Really black")
				grp1[i].Material = Enum.Material.SmoothPlastic
		grp1[i].Light.Enabled = false
	end
	
	for i = 1,#grp2 do
		grp2[i].Material = Enum.Material.SmoothPlastic
		grp2[i].Light.Enabled = false
	end
	
	

end
end]]></ProtectedString>
