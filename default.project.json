{
  "name": "Obby-Cybertruck-Lincoln",
  "tree": {
    "$className": "DataModel",

    "Workspace": {
      "$className": "Workspace",
      "MenuCameraAnchor": {
        "$className": "Part",
        "Transparency": {
          "$type": "Float",
          "$value": 1
        },
        "CanCollide": {
          "$type": "Bool",
          "$value": false
        },
        "Anchored": {
          "$type": "Bool",
          "$value": true
        }
      }
    },

    "ServerScriptService": {
      "$path": "src/ServerScriptService"
    },

    "ServerStorage": {
      "$className": "ServerStorage",
      "RaceHandlers": {
        "$className": "Folder",
        "ProcessRaceTime": {
          "$className": "BindableFunction"
        },
        "ProcessRaceCoins": {
          "$className": "BindableFunction"
        }
      }
    },

    "ReplicatedStorage": {
      "$path": "src/ReplicatedStorage",
      "OpenPaintShop": {
        "$className": "RemoteEvent"
      },
      "PurchaseSuccess": {
        "$className": "RemoteEvent"
      },
      "ApplyPaintJob": {
        "$className": "RemoteEvent"
      },
      "ApplyBoost": {
        "$className": "RemoteEvent"
      },
      "BundlePurchased": {
        "$className": "RemoteEvent"
      },
      "MapPurchased": {
        "$className": "RemoteEvent"
      },
      "OwnedMapsSync": {
        "$className": "RemoteEvent"
      },
      "Events": {
        "$className": "Folder",
        "OpenGarage": {
          "$className": "RemoteEvent"
        },
        "EquipVehicle": {
          "$className": "RemoteEvent"
        }
      },
      "Race": {
        "$className": "Folder",
        "CheckpointReached": {
          "$className": "RemoteEvent"
        },
        "RaceStarted": {
          "$className": "RemoteEvent"
        },
        "RaceFinished": {
          "$className": "RemoteEvent"
        },
        "RaceAgain": {
          "$className": "RemoteEvent"
        }
      }
    },

    "StarterPlayer": {
      "$path": "src/StarterPlayer"
    },

    "StarterGui": {
      "$path": "src/StarterGui"
    }
  }
