				<Item class="LocalScript" referent="RBX18B180847E854325A05535629E49BD3C">
					<Properties>
						<ProtectedString name="Source">local car = script.Parent:WaitForChild("Car").Value
local rs = game:GetService("RunService")
local wheelModel = car:WaitForChild("Wheels")
local handler = car:WaitForChild("DustEvent")
local touchingParts = {}

for index, wheel in pairs(wheelModel:GetChildren()) do
	wheel.Touched:Connect(function(part)
		touchingParts[index] = part
	end)
end

rs.Heartbeat:Connect(function()
	for index, wheel in pairs(wheelModel:GetChildren()) do
		local dustEffect = wheel:FindFirstChild("DustEffect")
		if not dustEffect then
			continue
		end

		local speed = wheel.Velocity.Magnitude
		local touchedPart = touchingParts[index]
		if speed &lt;= 20 or not touchedPart or not touchedPart.Parent then
			handler:FireServer("updateRate", dustEffect, 0)
			continue
		end

		if touchedPart:IsA("Terrain") then
			handler:FireServer("updateRate", dustEffect, 26 / 100 * speed * 10)
			handler:FireServer("updateColor", dustEffect, Color3.fromRGB(194, 178, 128))
		elseif touchedPart.Material == Enum.Material.Grass or touchedPart.Material == Enum.Material.Pebble then
			handler:FireServer("updateRate", dustEffect, 26 / 100 * speed * 10)
			handler:FireServer("updateColor", dustEffect, Color3.fromRGB(86, 66, 54))
		elseif touchedPart.Material == Enum.Material.Sand then
			handler:FireServer("updateRate", dustEffect, 26 / 100 * speed * 10)
			handler:FireServer("updateColor", dustEffect, touchedPart.Color)
		else
			handler:FireServer("updateRate", dustEffect, 0)
		end
	end
end)</ProtectedString>
