							<Properties>
								<ProtectedString name="Source">local F = {}

F.updateRate = function(v, rate)
	v.Rate = rate
end

F.updateColor = function(v, color)
	v.Color = ColorSequence.new(color)
end

script.Parent.OnServerEvent:connect(function(pl,Fnc,...)
	F[Fnc](...)
end)

local car = script.Parent.Parent
local wheels = car.Wheels

for i, v in pairs(wheels:GetChildren()) do
	if v.Name == "FL" or v.Name == "FR" or v.Name == "RL" or v.Name == "RR" then
		local a = script.Parent.DustEffect:Clone()
		a.Parent = v
	end
end</ProtectedString>
