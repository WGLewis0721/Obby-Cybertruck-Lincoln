						<Item class="LocalScript" referent="RBXA2D6408023CE4C0B84BA4F71138D9512">
							<Properties>
								<ProtectedString name="Source">local mouse=game.Players.LocalPlayer:GetMouse()
script.Parent:WaitForChild("src")
local src = script.Parent.src.Value
if not src then
	return
end
mouse.KeyDown:connect(function(key)
	if key=="h" then 
		src:Play()
	end
end)
mouse.KeyUp:connect(function(key)
	if key=="h" then 
		src:Stop()
	end
end)
src.Parent.ChildRemoved:connect(function(child)
	if child.Name=="SeatWeld" then 
		src:Stop()
		script.Parent:Destroy()
	end
end)</ProtectedString>
