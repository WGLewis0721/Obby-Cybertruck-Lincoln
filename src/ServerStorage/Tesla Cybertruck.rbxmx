						<UniqueId name="UniqueId">1a95347810b6254c083267f300005ee8</UniqueId>
					</Properties>
					<Item class="RemoteEvent" referent="RBX8775F2B752FE463182B69EC26AB2E1BF">
						<Properties>
							<BinaryString name="AttributesSerialize" />
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">AC6_FE_Sounds</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags" />
							<UniqueId name="UniqueId">1a95347810b6254c083267f300005ee9</UniqueId>
						</Properties>
						<Item class="Script" referent="RBX8C2F67083BC74E928338B0196C4CDBD5">
							<Properties>
								<ProtectedString name="Source">local car = script.Parent.Parent
local driveSeat = car:WaitForChild("DriveSeat")
local Sounds = {}
local F = {}

F.newSound = function(name,par,id,pitch,volume,loop)
	for i,v in pairs(Sounds) do
		if i==name then
			v:Stop()
			v:Destroy()
		end
	end
	local sn = Instance.new("Sound",par)
	sn.Name = name
	sn.SoundId = id
	sn.Pitch = pitch
	sn.Volume = volume
	sn.Looped = loop
	Sounds[name]=sn
end

F.updateSound = function(sound,id,pit,vol)
	local sn = Sounds[sound]
	if not sn then return end
	if id~=sn.SoundId then sn.SoundId = id end
	if pit~=sn.Pitch then sn.Pitch = pit end
	if vol~=sn.Volume then sn.Volume = vol end
end

F.playSound = function(sound)
	local sn = Sounds[sound]
	if sn then sn:Play() end
end

F.pauseSound = function(sound)
	local sn = Sounds[sound]
	if sn then sn:Pause() end
end

F.stopSound = function(sound)
	local sn = Sounds[sound]
	if sn then sn:Stop() end
end

F.removeSound = function(sound)
	local sn = Sounds[sound]
	if not sn then return end
	sn:Stop()
	sn:Destroy()
	Sounds[sound]=nil
end

script.Parent.OnServerEvent:connect(function(pl,Fnc,...)
	F[Fnc](...)
end)

driveSeat.ChildRemoved:connect(function(child)
	if child.Name=="SeatWeld" then
		F.removeSound("Rev")
		F.removeSound("Elec")
	end
end)</ProtectedString>
