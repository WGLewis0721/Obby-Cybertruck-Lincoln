				<Item class="LocalScript" referent="RBXDBFC8C2D89004D9AAD95F5A92FE314A6">
					<Properties>
						<ProtectedString name="Source">local car = script.Parent.Car.Value
local driveSeat = car:WaitForChild("DriveSeat")

script:WaitForChild("Start1")
script:WaitForChild("Start2")

for i,v in pairs(driveSeat:GetChildren()) do
	for _,a in pairs(script:GetChildren()) do
		if v.Name==a.Name then v:Stop() wait() v:Destroy() end
	end
end

local s1=script.Start1
local s2=script.Start2

s1.Parent=driveSeat
s2.Parent=driveSeat
wait()
s1:Play()
wait(7.3)
s2:Play()
script.Parent.IsOn.Value=true
wait()
s1:Stop()
s2:Stop()</ProtectedString>
